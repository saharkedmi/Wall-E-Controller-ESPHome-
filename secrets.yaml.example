# secrets.yaml.example
#
# Copy this file to secrets.yaml and fill in your real values.
# The real secrets.yaml must never be committed to git
# (it is already listed in .gitignore).

wifi_ssid: "YourWiFiSSID"
wifi_password: "YourWiFiPassword"

# Encryption key for the ESPHome Native API.
# Generate a valid key (base64, 32 bytes) with:
#   esphome generate-key wall-e-controller
api_encryption_key: "REPLACE_WITH_GENERATED_BASE64_KEY"

# OTA update password
ota_password: "REPLACE_WITH_OTA_PASSWORD"

# Password for the fallback access point that comes up if WiFi is unavailable
ap_password: "REPLACE_WITH_FALLBACK_AP_PASSWORD"
